{
    "name": "sofyco/wordpress-gateway-bundle",
    "type": "symfony-bundle",
    "version": "1.2.0",
    "description": "Symfony WordPress Gateway Bundle",
    "keywords": ["php", "symfony", "wordpress", "gateway", "bundle"],
    "homepage": "https://github.com/sofyco/wordpress-gateway-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Sofiia Korzhova",
            "email": "sofykorzhova@gmail.com"
        }
    ],
    "require": {
        "ext-pdo": "*",
        "php": "^8.5",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/validator": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "Sofyco\\Bundle\\WordPressGatewayBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sofyco\\Bundle\\WordPressGatewayBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
